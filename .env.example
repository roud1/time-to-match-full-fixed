# Time to Match — server / database (optional; demo UI works without these)
#
# Local Postgres (docker-compose up -d):
# DATABASE_URL=postgresql://ttm:ttm_dev_password@127.0.0.1:5432/timetomatch
#
# Then: npm run db:migrate

# PostgreSQL connection (postgres.js)
DATABASE_URL=

# Pool size for API routes (optional)
DATABASE_POOL_MAX=10

# HS256 secret for httpOnly session cookie (use `openssl rand -base64 32` in production)
AUTH_SECRET=

# Canonical public URL (required for correct OG URLs, sitemap, and PWA in production)
NEXT_PUBLIC_APP_URL=https://your-domain.example

# Comma-separated browser origins allowed to call /api/v1 with credentials (optional)
# CORS_ORIGINS=https://your-domain.example

# Set to 1 to disable client analytics beacons during local development
# NEXT_PUBLIC_ANALYTICS_DISABLED=1

# Pulse AI — полноценный диалог (OpenAI или совместимый API)
# Без ключа работают короткие локальные ответы; с ключом — живая переписка с памятью контекста.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Необязательно: другой хост (Groq, OpenRouter, локальный прокси)
# OPENAI_BASE_URL=https://api.openai.com/v1

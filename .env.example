# Time to Match — environment template
# Copy to .env.local for local dev:  cp .env.example .env.local
# Or run: npm run db:setup  (docker Postgres + migrate + .env.local)
#
# Demo mode: leave DATABASE_URL empty — UI works with localStorage only.
# Production mode: set DATABASE_URL + AUTH_SECRET (and vars below on hosted deploy).

# =============================================================================
# Required for production (server mode)
# =============================================================================

# PostgreSQL connection (postgres.js)
# Local (docker-compose): postgresql://ttm:ttm_dev_password@127.0.0.1:5432/timetomatch
DATABASE_URL=

# HS256 secret for httpOnly session cookie — min 32 chars in production
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Canonical public URL (required on Vercel/Render/Railway for OG, sitemap, PWA)
NEXT_PUBLIC_APP_URL=https://your-domain.example

# Cron auth for /api/v1/cron/notify, /api/v1/cron/expire-matches, /api/v1/cron/cleanup, and /api/v1/cron/ai-analysis
# Vercel Cron sends Authorization: Bearer …; manual curl may use x-cron-secret
CRON_SECRET=

# =============================================================================
# Optional
# =============================================================================

# Pool size for API routes (default 10)
# DATABASE_POOL_MAX=10

# Comma-separated browser origins for credentialed /api/v1 calls
# CORS_ORIGINS=https://your-domain.example

# Set to 1 to disable client analytics beacons during local development
# NEXT_PUBLIC_ANALYTICS_DISABLED=1

# Photo verification admin API (PUT /api/admin/verification/:id) — header x-admin-key
# ADMIN_API_KEY=

# OpenRouter — server-only AI (connection analysis + Pulse chat)
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Generate VAPID keys for Web Push (copy output into .env.local):
# node scripts/generate-vapid-keys.mjs
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   ← same value as VAPID_PUBLIC_KEY (client subscribe)
# VAPID_SUBJECT=mailto:support@your-domain.example

# Resend — expiry email notifications + password reset emails
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Notification email/push copy locale when user locale is unknown (ru | en)
# NOTIFICATION_LOCALE=en

# Sentry — optional error tracking (no-op if unset)
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=time-to-match

# Upstash Redis — shared rate limiting + realtime ephemeral state (optional; in-memory fallback in dev)
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Stripe — Premium / VIP subscriptions (Phase 3)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Enable Customer Portal in Stripe Dashboard → Settings → Billing → Customer portal
# Webhook events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Realtime — WebSocket via Pusher (recommended) or Ably REST; polling fallback without these
# Pusher free tier: https://pusher.com — enable "Client events" off; use private channels
# PUSHER_APP_ID=...
# PUSHER_KEY=...
# PUSHER_SECRET=...
# PUSHER_CLUSTER=eu
# NEXT_PUBLIC_PUSHER_KEY=...          ← same as PUSHER_KEY (browser)
# NEXT_PUBLIC_PUSHER_CLUSTER=eu       ← same as PUSHER_CLUSTER
# Ably alternative (server publish only unless you add ably client):
# ABLY_API_KEY=...

# S3/R2 photo uploads (optional — base64 fallback in demo mode)
# Cloudflare R2 example:
# S3_BUCKET=ttm-photos
# S3_REGION=auto
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_PUBLIC_URL=https://photos.your-domain.example
# AWS aliases also supported: AWS_S3_BUCKET, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION

# Exit on missing required env at startup (CI / Docker)
# TTM_STRICT_ENV=1
